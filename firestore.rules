// ═══════════════════════════════════════════════════════════════
//  firestore.rules — EPJ App Globale v2.0.0
//
//  Stratégie :
//   • Tout est REFUSÉ par défaut (deny-all)
//   • L'utilisateur doit être authentifié pour lire/écrire
//   • Le rôle vient du custom claim Auth `request.auth.token.role`
//     (posé par les Cloud Functions adminCreateUser / adminUpdateUser)
//   • Les opérations destructives (delete) sont réservées à Admin
//   • Les collections de référence (config, catégories) ne sont modifiables
//     que par Admin/Direction
//   • Les utilisateurs ne peuvent modifier que leur propre fiche (sauf Admin)
//   • Les Cloud Functions tournent en service account et bypassent ces règles
//
//  Pour tester localement : firebase emulators:start --only firestore
//  Pour déployer : firebase deploy --only firestore:rules
// ═══════════════════════════════════════════════════════════════

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function role() {
      return request.auth.token.role;
    }
    function isAdmin() {
      return isSignedIn() && role() == "Admin";
    }
    function isDirection() {
      return isSignedIn() && (role() == "Admin" || role() == "Direction");
    }
    function isConducteur() {
      return isSignedIn() && (
        role() == "Admin" ||
        role() == "Direction" ||
        role() == "Conducteur travaux"
      );
    }
    function isAssistante() {
      return isSignedIn() && (
        role() == "Admin" ||
        role() == "Direction" ||
        role() == "Conducteur travaux" ||
        role() == "Assistante"
      );
    }
    function isAchat() {
      return isSignedIn() && role() == "Achat";
    }
    // Tout user authentifié et avec un rôle valide (= au moins Monteur/Artisan)
    function isEmployee() {
      return isSignedIn() && role() != null;
    }
    // Vérifie que l'utilisateur ne change pas le champ `role` côté Firestore
    // (le rôle effectif est dans le claim Auth posé par adminUpdateUser)
    function rolesUnchanged() {
      return request.resource.data.roles == resource.data.roles
          && request.resource.data.role == resource.data.role;
    }

    // ─── utilisateurs/{uid} ───────────────────────────────────────
    // Lecture : tous les employés (pour afficher l'annuaire interne)
    // Écriture : Admin uniquement, OU l'utilisateur sur sa propre fiche
    //            (mais sans pouvoir modifier son rôle)
    match /utilisateurs/{uid} {
      allow read: if isEmployee();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
                    || (isEmployee() && request.auth.uid == uid && rolesUnchanged());
    }

    // ─── rolesConfig/{role} ───────────────────────────────────────
    // Configuration des permissions par rôle (override des FACTORY)
    // Lecture : tous (l'app a besoin de ces overrides au démarrage)
    // Écriture : Admin uniquement
    match /rolesConfig/{role} {
      allow read: if isEmployee();
      allow write: if isAdmin();
    }

    // ─── chantiers/{id} ───────────────────────────────────────────
    // Référentiel central, partagé par tous les modules
    // Lecture : tous les employés
    // Création / modification : Admin / Direction / Conducteur / Assistante
    //   + Chef chantier (L9 : il valide l'avancement de ses tâches planifiées
    //   comme le conducteur — écriture bornée à avancementProgress côté client).
    // Suppression : Admin uniquement
    match /chantiers/{id} {
      allow read: if isEmployee();
      allow create, update: if isAssistante() || role() == "Chef chantier";
      allow delete: if isAdmin();
    }

    // ─── commandes/{id} ───────────────────────────────────────────
    // Module Commandes — les règles métier fines sont vérifiées côté app
    // (le système à 3 couches dans permissions.js gère view/edit/delete
    // par scope own_chantiers / own_items)
    // Lecture : tous les employés (filtré côté UI)
    // Création / update : tous les employés (l'app filtre par rôle)
    // Suppression : Admin / Direction / Conducteur travaux
    match /commandes/{id} {
      allow read: if isEmployee();
      allow create, update: if isEmployee();
      allow delete: if isConducteur();
    }

    // ─── reserves/{id} ────────────────────────────────────────────
    // Module Réserves & quitus
    match /reserves/{id} {
      allow read: if isEmployee();
      allow create, update: if isEmployee();
      allow delete: if isConducteur();

      // Sous-collections (timeline, pièces jointes…)
      match /{subcoll=**} {
        allow read: if isEmployee();
        allow write: if isEmployee();
      }
    }
    match /reservesCategories/{id} {
      allow read: if isEmployee();
      allow write: if isAssistante();
    }
    match /reservesEmetteurs/{id} {
      allow read: if isEmployee();
      allow write: if isAssistante();
    }
    match /reserveMails/{id} {
      // Écrit principalement par la Cloud Function gmailPoll (service account)
      // Lecture par les employés pour la timeline
      allow read: if isEmployee();
      allow create, update: if isEmployee();
      allow delete: if isAdmin();
    }
    match /reserveMailsAClasser/{id} {
      allow read: if isEmployee();
      allow create, update: if isEmployee();
      allow delete: if isAdmin();
    }
    match /mailOutbox/{id} {
      // Mails sortants en file d'attente — déposés par l'app, traités par gmailSend
      allow read: if isEmployee();
      allow create: if isEmployee();
      allow update, delete: if false; // Seules les Cloud Functions y touchent
    }

    // ─── outils + parc machines ───────────────────────────────────
    // Achat gère l'intégralité du parc machines (ajouté juin 2026 sans rien
    // retirer des droits existants).
    match /outils/{id} {
      allow read: if isEmployee();
      allow create, update: if isAssistante() || isAchat();
      allow delete: if isAdmin() || isAchat();
    }
    match /outillageSorties/{id} {
      allow read: if isEmployee();
      allow create, update: if isEmployee();
      allow delete: if isAdmin() || isAchat();
    }
    match /outillageCategories/{id} {
      allow read: if isEmployee();
      allow write: if isAdmin() || isAchat();
    }
    match /outillagePannes/{id} {
      allow read: if isEmployee();
      allow write: if isAdmin() || isAchat();
    }
    // Interventions SAV (déclaration de panne autonome + suivi). Collection
    // complémentaire d'outillageSorties (calque ses droits) : tout employé
    // crée/édite, suppression réservée à l'admin (ou Achat, gestionnaire parc).
    match /outillageInterventions/{id} {
      allow read: if isEmployee();
      allow create, update: if isEmployee();
      allow delete: if isAdmin() || isAchat();
    }

    // ─── avancement chantier ──────────────────────────────────────
    match /avancementValidations/{id} {
      allow read: if isEmployee();
      allow create, update: if isEmployee();
      allow delete: if isAdmin();
    }

    // ─── pieuvres/{id} — M5 Gestion de chantier (onglet Pieuvres) ──
    // Per-chantier, éditable par tout employé (le gating fin Admin/Direction/
    // Conducteur own_chantiers est assuré côté client par can()). Suppression
    // réservée au conducteur (calque reserves/commandes).
    match /pieuvres/{id} {
      allow read: if isEmployee();
      allow create, update: if isEmployee();
      allow delete: if isConducteur();
    }

    // ─── conges/{id} — Module RH (onglet Congés / absences) ──────
    // Calque pieuvres : lecture + création/mise à jour par tout employé
    // authentifié (le gating fin rh.conges est assuré côté client par can()).
    // PAS de delete client : l'annulation d'un congé passe par un update
    // statut = "ANNULE" (V1 sans workflow de validation).
    match /conges/{id} {
      // Gestionnaire congés = saisie directe (VALIDEE) + maladie : Direction/Assistante/Admin.
      function isGestionnaireConges() {
        return isSignedIn() && (role() == "Admin" || role() == "Direction" || role() == "Assistante");
      }
      allow read: if isEmployee();

      // Création : un gestionnaire peut poser n'importe quel statut (VALIDEE direct /
      // maladie) ; tout autre employé ne peut créer qu'une DEMANDE (pas d'auto-validation).
      allow create: if isEmployee()
        && (isGestionnaireConges() || request.resource.data.statut == "DEMANDE");

      // Mise à jour — les transitions de VALIDATION sont réservées aux bons rôles :
      //  • → VALIDEE_N1 : N1 = conducteur (isConducteur inclut Direction/Admin)
      //  • → VALIDEE    : N2 = gestionnaire (Direction/Assistante/Admin)
      //  • → REFUSEE    : un validateur N1 OU N2
      //  • statut inchangé (édition) ou → ANNULEE : tout employé (gating fin côté client)
      allow update: if isEmployee() && (
           request.resource.data.statut == resource.data.statut
        || (request.resource.data.statut == "VALIDEE_N1" && isConducteur())
        || (request.resource.data.statut == "VALIDEE"    && isGestionnaireConges())
        || (request.resource.data.statut == "REFUSEE"    && (isConducteur() || isGestionnaireConges()))
        || request.resource.data.statut == "ANNULEE"
      );

      // Pas de delete (annulation = update statut "ANNULEE").
    }

    // ─── rhSoldes/{ressourceId} — soldes RH par personne (RH-3a) ────
    // Soldes CP / RCR isolés de la fiche `utilisateurs` (aucune écriture sur
    // utilisateurs). Lecture tout employé (le salarié voit son solde) ;
    // saisie réservée au gestionnaire congés (Direction/Assistante/Admin).
    match /rhSoldes/{id} {
      function isGestionnaireConges() {
        return isSignedIn() && (role() == "Admin" || role() == "Direction" || role() == "Assistante");
      }
      allow read: if isEmployee();
      allow create, update: if isGestionnaireConges();
      // Pas de delete.
    }

    // ─── referentielFraisBTP/{annee} — barème petits déplacements FBTP ──
    // Barème conventionnel versionné par année (RH-Frais-1). Lecture tout
    // employé (référence consultable par les salariés) ; saisie/versionnement
    // réservés au gestionnaire RH (Direction/Assistante/Admin). Pas de delete
    // (l'historique des années reste figé).
    match /referentielFraisBTP/{annee} {
      function isGestionnaireRH() {
        return isSignedIn() && (role() == "Admin" || role() == "Direction" || role() == "Assistante");
      }
      allow read: if isEmployee();
      allow create, update: if isGestionnaireRH();
      // Pas de delete (on garde l'historique).
    }

    // ─── fraisDistances/{id} — cache distance routière (RH-Frais-2b) ──
    // docId = `${salarieId}__${chantierId}__${origineType}`. Écrit UNIQUEMENT
    // par la Cloud Function computeDistanceFrais (Admin SDK). Lecture employé.
    match /fraisDistances/{id} {
      allow read: if isEmployee();
      allow write: if false;   // Admin SDK only (Cloud Function)
    }

    // ─── heures/{id} — heures salariés importées Esabora (RH-Frais-3a) ──
    // Collection TRANSVERSE (RH frais + Suivi financier M5). id déterministe
    // `${mois}__${salarieId|NC-trigramme}__${chantierNum|NA}__${jour}`
    // (ré-import idempotent). Lecture tout employé ; écriture (import / correction)
    // réservée au gestionnaire RH (Admin/Direction/Assistante).
    match /heures/{id} {
      function isGestionnaireRH() {
        return isSignedIn() && (role() == "Admin" || role() == "Direction" || role() == "Assistante");
      }
      allow read: if isEmployee();
      allow create, update, delete: if isGestionnaireRH();
    }

    // ─── fraisMappingSalaries/{nomNormalise} — rapprochement nom fichier → user ──
    // Mémoire de résolution des noms non mappés à l'import (RH-Frais-3a).
    // Lecture tout employé ; écriture gestionnaire RH.
    match /fraisMappingSalaries/{nomNormalise} {
      function isGestionnaireRH() {
        return isSignedIn() && (role() == "Admin" || role() == "Direction" || role() == "Assistante");
      }
      allow read: if isEmployee();
      allow create, update, delete: if isGestionnaireRH();
    }

    // ─── planningCreneaux/{id} — Planning ressources (socle M5/RH) ──
    // V3 : un créneau est AFFECTÉ (ressourceId non nul, id déterministe) ou
    //   « à affecter » (pool, ressourceId null, doc auto-id). Mêmes droits.
    // read : tout employé (le client borne le Monteur à ses créneaux, scope
    //   own_items). create/update/delete UNIFORMES : Admin OU Assistante OU
    //   Conducteur OU Chef chantier (les conducteurs font le planning ; lève
    //   l'asymétrie create/delete → affecter/libérer/supprimer atomiques).
    //   isAdmin() est explicite (inoffensif même si couvert ailleurs).
    //   Le gating fin own_chantiers/own_items est assuré côté client par can().
    match /planningCreneaux/{id} {
      allow read: if isEmployee();
      allow create, update, delete: if isAdmin() || isAssistante() || isConducteur() || role() == "Chef chantier";
      // L9 — le Monteur flippe UNIQUEMENT sa confirmation (« Tâche faite »),
      //   désormais PAR TÂCHE (map validationMonteur.<tacheId>) + le flag
      //   aValiderConducteur. Bornée à ces 2 clés de tête → il ne peut PAS
      //   modifier taches[]/chantier/poste/temps ni la validation conducteur.
      //   Le client n'affiche que ses créneaux ; l'ownership stricte par uid
      //   viendra avec ressourceUid (V1 : périmètre champs uniquement).
      allow update: if role() == "Monteur"
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(["validationMonteur", "aValiderConducteur"]);
    }

    // ─── smsTemplates + smsQueue ──────────────────────────────────
    match /smsTemplates/{id} {
      allow read: if isEmployee();
      allow write: if isAdmin();
    }
    match /smsQueue/{id} {
      // L'app dépose des SMS, la Cloud Function onSmsQueueCreate les traite
      allow read: if isEmployee();
      allow create: if isEmployee();
      allow update, delete: if false; // Seule la Cloud Function modifie le statut
    }

    // ─── catalogue (produits Commandes) ───────────────────────────
    match /catalogue/{id} {
      allow read: if isEmployee();
      allow write: if isAssistante();
    }

    // ─── company (réglages entreprise) ────────────────────────────
    match /company/{id} {
      allow read: if isEmployee();
      allow write: if isAdmin();
    }

    // ─── errorLog (capture ErrorBoundary) ─────────────────────────
    // v2.0.0 — Les erreurs React non gérées sont loguées ici.
    // Tout employé authentifié peut écrire (pour pas perdre d'info),
    // seul l'admin peut lire (pour Diagnostics) et supprimer.
    match /errorLog/{id} {
      allow read: if isAdmin();
      allow create: if isEmployee();
      allow update, delete: if isAdmin();
    }

    // ─── config/{id} ──────────────────────────────────────────────
    // Configuration globale (settings, company, …) — chargée par DataContext
    // au démarrage de l'app pour tous les employés.
    // Lecture : tous les employés
    // Écriture : Admin uniquement
    match /config/{id} {
      allow read: if isEmployee();
      allow write: if isAdmin();
      // Direction : bascule UNIQUEMENT planningSmsEnabled sur config/settings.
      allow update: if isDirection()
        && id == "settings"
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["planningSmsEnabled"])
        && request.resource.data.planningSmsEnabled is bool;
    }

    // ─── config/counters ─────────────────────────────────────────
    // Doc compteurs atomiques (CMD, extensible outils/réserves).
    // Lecture + écriture par tous les employés pour autoriser les
    // runTransaction Firestore côté client (numérotation atomique).
    match /config/counters {
      allow read, write: if isEmployee();
    }

    // ─── tasksConfig/{id} ─────────────────────────────────────────
    // Modèle global d'avancement (config des tâches par défaut).
    // Lecture : tous les employés
    // Écriture : Admin uniquement
    match /tasksConfig/{id} {
      allow read: if isEmployee();
      allow write: if isAdmin();
    }

    // ─── commandesEsabora/{numero} ────────────────────────────────
    // Module Commande (suivi Esabora / AR fournisseurs). Documents écrits
    // par les Cloud Functions esaboraWebhook + gmailPollAchat (service
    // account, bypass des rules). Côté app : LECTURE pour tous les employés
    // (le filtrage de visibilité est fait côté UI via permissions.js), et
    // ÉCRITURE STRICTEMENT LIMITÉE aux 4 champs d'acquittement AR, réservée
    // aux rôles pilotage (Assistante+ = Admin/Direction/Conducteur/Assistante).
    // Aucune création / suppression côté client : seules les Cloud Functions
    // créent ou suppriment ces documents.
    match /commandesEsabora/{numero} {
      allow read: if isEmployee();
      allow create, delete: if false;
      allow update: if isAssistante()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['arAcquitte', 'arAcquitPar', 'arAcquitLe', 'arStatut']);
    }

    // ─── achatEcartsPrix/{numero__refNorm} ────────────────────────
    // Écarts de prix ligne à ligne (price-watch), écrits par gmailPollAchat
    // (service account). Lecture seule côté app pour le dashboard achat.
    match /achatEcartsPrix/{id} {
      allow read: if isEmployee();
      allow write: if false;
    }

    // ─── fournisseursContacts/{codeFournisseur} ───────────────────
    // Mémoire des adresses de réclamation par fournisseur. Écrite par la
    // Cloud Function prepareAchatReclamation (service account, bypass rules)
    // quand l'utilisateur valide/corrige le destinataire d'un brouillon.
    // Lecture seule côté app (pré-remplissage du modal de réclamation) ;
    // aucune écriture client (cohérent avec achatEcartsPrix / commandesEsabora).
    match /fournisseursContacts/{codeFournisseur} {
      allow read: if isEmployee();
      allow write: if false;
    }

    // ─── fournisseurs/{code} ──────────────────────────────────────
    // Référentiel fournisseurs PARTAGÉ (fiches + contacts), source unique du
    // Module Commande (relance AR) et des futures consultations Chiffrage.
    // Écrit aussi par prepareAchatReclamation (service account, auto-capture
    // des contacts source:"auto"). Côté app : LECTURE pour tous les employés,
    // ÉCRITURE réservée à la Direction / Admin (page admin Contacts fournisseurs).
    match /fournisseurs/{code} {
      allow read: if isEmployee();
      allow write: if isDirection();
    }

    // ─── Tout le reste : REFUSÉ ───────────────────────────────────
    // Toute collection non listée ci-dessus retombe sur ce deny-all.
    // Pour ajouter une nouvelle collection, ajouter explicitement sa règle.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
